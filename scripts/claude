#!/bin/bash
# Simulates interactive Claude Code for the VHS demo.
# Makes REAL file changes so snaprevert captures them.

# If called with -p, handle non-interactive mode
if [ "$1" = "-p" ]; then
  shift
  PROMPT="$*"
  if echo "$PROMPT" | grep -qi "auth"; then
    echo " Done."
  fi
  exit 0
fi

# Interactive mode
echo ""
echo "  Claude Code v2.1.84"
echo "  Type your request, or /exit to leave."
echo ""

while true; do
  printf "  > "
  read -r INPUT

  if [ -z "$INPUT" ]; then
    continue
  fi

  if [ "$INPUT" = "/exit" ] || [ "$INPUT" = "exit" ] || [ "$INPUT" = "q" ]; then
    echo ""
    echo "  Goodbye!"
    echo ""
    exit 0
  fi

  if echo "$INPUT" | grep -qi "auth\|login\|middleware"; then
    echo ""
    echo "  Thinking..."
    sleep 0.5
    echo ""
    echo "  I'll add authentication with password hashing and JWT middleware."
    echo ""

    cat > auth.js << 'EOF'
const crypto = require('crypto');

function hashPassword(password) {
  const salt = crypto.randomBytes(16).toString('hex');
  const hash = crypto.pbkdf2Sync(password, salt, 1000, 64, 'sha512').toString('hex');
  return { salt, hash };
}

function verifyPassword(password, salt, hash) {
  const verify = crypto.pbkdf2Sync(password, salt, 1000, 64, 'sha512').toString('hex');
  return verify === hash;
}

module.exports = { hashPassword, verifyPassword };
EOF

    cat > middleware.js << 'EOF'
function requireAuth(req, res, next) {
  const token = req.headers.authorization;
  if (!token) return res.status(401).json({ error: 'Unauthorized' });
  next();
}

module.exports = { requireAuth };
EOF

    cat > app.js << 'EOF'
const express = require('express');
const { requireAuth } = require('./middleware');
const { hashPassword, verifyPassword } = require('./auth');

const app = express();
app.use(express.json());

app.post('/login', (req, res) => {
  const { username, password } = req.body;
  const { salt, hash } = hashPassword(password);
  res.json({ token: 'jwt-token', user: username });
});

app.get('/dashboard', requireAuth, (req, res) => {
  res.json({ message: 'Welcome to dashboard' });
});

app.get('/', (req, res) => {
  res.json({ message: 'Hello World' });
});

app.listen(3000);
EOF

    sleep 0.3
    echo "  Write auth.js (+45 lines)"
    echo "  Write middleware.js (+8 lines)"
    echo "  Edit app.js (+12 lines)"
    echo ""
    echo "  Created auth module with password hashing, JWT middleware,"
    echo "  and added /login + /dashboard routes to app.js."
    echo ""

  elif echo "$INPUT" | grep -qi "typescript\|TS\|refactor\|convert"; then
    echo ""
    echo "  Thinking..."
    sleep 0.5
    echo ""
    echo "  I'll convert the project to TypeScript."
    echo ""

    cat > app.js << 'EOF'
import express, { Request, Response } from 'express';
import { requireAuth } from './middleware';

// BUG: auth module was deleted during conversion
const app: express.Application = express();

app.post('/login', (req: Request, res: Response) => {
  // TODO: re-implement with TypeScript types
});

EOF

    rm -f config.js
    rm -f auth.js

    sleep 0.3
    echo "  Edit app.js (converted to TS imports)"
    echo "  Delete config.js (merged into app config)"
    echo "  Delete auth.js (needs rewrite as auth.ts)"
    echo ""
    echo "  Converted to TypeScript. Note: middleware.js still uses"
    echo "  CommonJS — you may want to convert that too."
    echo ""

  else
    echo ""
    echo "  I'm a demo stub. Try asking about authentication or TypeScript."
    echo ""
  fi
done
