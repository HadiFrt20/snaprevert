#!/bin/bash
# Demo wrapper - intercepts claude -p calls and makes real file changes
# with realistic-looking output, instantly.

shift # skip -p flag
PROMPT="$*"

if echo "$PROMPT" | grep -qi "authentication\|auth\|login"; then
  sleep 0.5
  echo ""
  echo " I'll add authentication to your Express app."
  echo ""

  cat > auth.js << 'EOF'
const crypto = require('crypto');

function hashPassword(password) {
  const salt = crypto.randomBytes(16).toString('hex');
  const hash = crypto.pbkdf2Sync(password, salt, 1000, 64, 'sha512').toString('hex');
  return { salt, hash };
}

function verifyPassword(password, salt, hash) {
  const verify = crypto.pbkdf2Sync(password, salt, 1000, 64, 'sha512').toString('hex');
  return verify === hash;
}

module.exports = { hashPassword, verifyPassword };
EOF

  cat > middleware.js << 'EOF'
function requireAuth(req, res, next) {
  const token = req.headers.authorization;
  if (!token) return res.status(401).json({ error: 'Unauthorized' });
  next();
}

module.exports = { requireAuth };
EOF

  cat > app.js << 'EOF'
const express = require('express');
const { requireAuth } = require('./middleware');
const { hashPassword, verifyPassword } = require('./auth');

const app = express();
app.use(express.json());

app.post('/login', (req, res) => {
  const { username, password } = req.body;
  const { salt, hash } = hashPassword(password);
  res.json({ token: 'jwt-token', user: username });
});

app.get('/dashboard', requireAuth, (req, res) => {
  res.json({ message: 'Welcome to dashboard' });
});

app.get('/', (req, res) => {
  res.json({ message: 'Hello World' });
});

app.listen(3000);
EOF

  sleep 0.3
  echo " Created auth.js — password hashing with crypto"
  echo " Created middleware.js — JWT auth middleware"
  echo " Updated app.js — added /login and /dashboard routes"
  echo ""
  echo " 3 files changed (+2 new, ~1 modified)"

elif echo "$PROMPT" | grep -qi "typescript\|TS"; then
  sleep 0.5
  echo ""
  echo " I'll convert the project to TypeScript."
  echo ""

  cat > app.js << 'EOF'
import express, { Request, Response } from 'express';
import { requireAuth } from './middleware';

// BUG: auth module was deleted during conversion
const app: express.Application = express();

app.post('/login', (req: Request, res: Response) => {
  // TODO: re-implement with TypeScript types
});

EOF

  rm -f config.js
  rm -f auth.js

  sleep 0.3
  echo " Converted app.js to TypeScript import syntax"
  echo " Removed config.js (merged into app config)"
  echo " Removed auth.js (needs rewrite as auth.ts)"
  echo ""
  echo " WARNING: middleware.js still uses CommonJS"
  echo " 1 modified, 2 deleted"

else
  echo " Done."
fi
