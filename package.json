{
  "name": "snaprevert",
  "version": "0.1.0",
  "description": "The undo button for AI-assisted coding. Auto-snapshots your project, instant rollback.",
  "bin": {
    "snaprevert": "./bin/snaprevert.js"
  },
  "scripts": {
    "test": "npx jest --verbose",
    "test:unit": "npx jest --testPathPattern=unit --verbose",
    "test:integration": "npx jest --testPathPattern=integration --verbose",
    "test:uat": "npx jest --testPathPattern=uat --verbose",
    "test:coverage": "npx jest --coverage --verbose",
    "lint": "npx eslint src/ bin/ tests/"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000,
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 85,
        "lines": 85,
        "statements": 85
      }
    }
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "chokidar": "^3.6.0",
    "commander": "^11.0.0"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "jest": "^29.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
